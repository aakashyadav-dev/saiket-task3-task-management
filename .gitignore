# .gitignore

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
dist-ssr/
build/
*.local

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Cache directories
.cache/
.parcel-cache/
.next/
.nuxt/
.vuepress/dist/
.temp/

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini

# Testing coverage
coverage/
.nyc_output/

# TypeScript
*.tsbuildinfo

# ESLint
.eslintcache

# Vite
.vite/

# Local Netlify folder
.netlify/

# Optional: Ignore package-lock.json if you prefer
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Temporary files
tmp/
temp/

# Debug files
*.log

# System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development files
*.sublime-project
*.sublime-workspace
.ftpconfig
.remote-sync.json

# Project specific
# If you want to keep sample tasks data for demo, remove this line
# tasks-backup.json

# VSCode workspace settings (if you want to share with team)
!.vscode/extensions.json
!.vscode/settings.json